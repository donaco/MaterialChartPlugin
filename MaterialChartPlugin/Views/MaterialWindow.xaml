<metro:MetroWindow x:Class="MaterialChartPlugin.Views.MaterialWindow"
				   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				   xmlns:metro="http://schemes.grabacr.net/winfx/2014/controls"
				   xmlns:kcvc="http://schemes.grabacr.net/winfx/2015/kancolleviewer/controls"
				   xmlns:views="clr-namespace:MaterialChartPlugin.Views"
				   xmlns:vm="clr-namespace:MaterialChartPlugin.ViewModels"
				   mc:Ignorable="d"
				   d:DataContext="{d:DesignInstance vm:ToolViewModel}"
				   Title="MaterialChart"
				   Width="720"
				   Height="680"
				   FontSize="12"
				   Background="{DynamicResource ThemeBrushKey}"
				   Foreground="{DynamicResource ActiveForegroundBrushKey}"
				   FontFamily="{DynamicResource DefaultFontFamilyKey}"
				   SnapsToDevicePixels="True"
				   Topmost="{Binding IsTopMost, Mode=TwoWay}"
				   TextOptions.TextFormattingMode="Display">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- #region CaptionBar -->
        <Border metro:MetroWindow.IsCaptionBar="True"
				Panel.ZIndex="100">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <kcvc:AppIcon Width="36"
							  Height="36"
							  Background="Transparent"
							  AnchorVisibility="Collapsed"
							  BandVisibility="Collapsed" />

                <TextBlock Grid.Column="1"
						   Text="MaterialChart"
						   Style="{DynamicResource CaptionTextStyleKey}"
						   Margin="2,0,8,0" />

                <StackPanel Grid.Column="2"
							Orientation="Horizontal"
							VerticalAlignment="Top"
							WindowChrome.IsHitTestVisibleInChrome="True">
                    <metro:CaptionButton IsChecked="{Binding IsTopMost, Mode=TwoWay}"
										 ToolTip="常に最前面に表示"
										 Style="{DynamicResource PinButtonStyleKey}" />
                    <metro:SystemButtons HorizontalAlignment="Right"
										 VerticalAlignment="Top" />
                </StackPanel>
            </Grid>
        </Border>
        <!-- #endregion -->

        <!-- コンテンツ: ToolView をそのまま埋め込み -->
        <views:ToolView Grid.Row="1"
						 Margin="4" />
    </Grid>
</metro:MetroWindow>

